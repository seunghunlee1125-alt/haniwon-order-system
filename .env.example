# ────────────────────────────────────────────────
# 1. PostgreSQL 연결 문자열
#    형식: postgresql://유저:비밀번호@호스트:포트/DB명
# ────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/haniwon_db"

# ────────────────────────────────────────────────
# 2. NextAuth 설정
#    NEXTAUTH_SECRET: 임의의 긴 문자열 (openssl rand -base64 32)
#    NEXTAUTH_URL: 개발 시 http://localhost:3000
# ────────────────────────────────────────────────
NEXTAUTH_SECRET="your-secret-key-change-this"
NEXTAUTH_URL="http://localhost:3000"
